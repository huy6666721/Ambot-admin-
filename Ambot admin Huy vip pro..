-- Hàm tạo Tab chức năng
function CreateFeaturesTab()
    local Tab = Window:CreateTab("ESP & Aimbot", nil)
    _G.ESP = false _G.Skel = false _G.Aimbot = false
    
    Tab:CreateToggle({Name = "Box & Line ESP", Callback = function(v) _G.ESP = v end})
    Tab:CreateToggle({Name = "Skeleton ESP", Callback = function(v) _G.Skel = v end})
